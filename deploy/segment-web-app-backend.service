[Unit]
Description=Segment Web App FastAPI backend
After=network.target

[Service]
User=your-user
Group=www-data
WorkingDirectory=/home/your-user/ujp_segmentation_app
EnvironmentFile=/home/your-user/ujp_segmentation_app/deploy/backend.env
ExecStart=/home/your-user/ujp_segmentation_app/venv/bin/uvicorn backend.app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
