[Unit]
Description=Segment Web App FastAPI backend
After=network.target

[Service]
User=your-user
Group=www-data
WorkingDirectory=/home/your-user/ujp_segmentation_app
Environment="COOKIE_SAMESITE=none"
Environment="COOKIE_SECURE=true"
Environment="CORS_ALLOW_ORIGINS=https://your-domain.example"
ExecStart=/home/your-user/ujp_segmentation_app/venv/bin/uvicorn backend.app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
